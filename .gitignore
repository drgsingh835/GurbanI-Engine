# Git Ignore for GurbanI Engine Monorepo

# Environment secrets
.env
.env_backup
*.env*
.env.*
**/config/youtube/


# Python caches and compiled files
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.ipynb_checkpoints/

# Virtual Environments
venv/
.venv/
env/
.env/

# Large media assets, inputs, and outputs (to avoid hitting GitHub size limits)
**/01-inputs/
**/04-assets/
**/05-outputs/
**/*.mp3
**/*.wav
**/*.mp4
**/*.avi
**/*.mov
**/*.mkv
**/scratch_block_1_raw
**/test_pa.mp3
**/test_pa_en.mp3
**/test_pa_female.mp3
**/test_en.mp3

# Editor and system files
.vscode/
.idea/
.DS_Store
Thumbs.db
*.bak
# EXCEPT for our .git.bak folder backup, we want to ignore all .git.bak folders as well
**/.git.bak/
